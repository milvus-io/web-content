        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "projectName": {
                    "type": "string",
                    "description": "The name of the project to create.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "待创建项目的名称。"
                      }
                    }
                  },
                  "plan": {
                    "type": "string",
                    "description": "The subscription plan of the project. The possible values are `Standard`, `Enterprise`, and `BusinessCritical`.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "项目的订阅计划。当前仅支持 `Enterprise` 一种。"
                      }
                    },
                    "default": "Standard"
                  },
                  "regionIds": {
                    "type": "array",
                    "description": "A list of region IDs to bind to the project. When the `plan` is `Enterprise`, only a single region is allowed. To bind multiple regions, the `BusinessCritical` plan is required. Note that the `BusinessCritical` plan may not be available in all environments.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "要绑定到项目的地域 ID 列表。当订阅计划为 `Enterprise` 时，仅允许指定单个地域。如需绑定多个地域，需要使用 `BusinessCritical` 订阅计划。请注意，`BusinessCritical` 订阅计划在某些环境中可能不可用。"
                      }
                    },
                    "items": {
                      "type": "string",
                      "description": "A region ID. You can use the [List regions](https://docs.zilliz.com/reference/restful/list-cloud-regions-v2) to list applicable region IDs.",
                      "x-i18n": {
                        "zh-CN": {
                          "description": "地域 ID。您可以使用 [查看云服务地域](https://docs.zilliz.com.cn/reference/restful/list-cloud-regions-v2) 来获取可用地域 ID。"
                        }
                      }
                    }
                  }
                },
                "required": [
                  "projectName",
                  "plan"
                ]
              },
              "example": {
                "projectName": "My Project",
                "plan": "Enterprise",
                "regionIds": ["aws-us-east-1"]
              }
            }
          }
        },
