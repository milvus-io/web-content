      "post": {
        "summary": "Create Project",
        "deprecated": false,
        "description": "This operation creates a new project with a specified name and subscription plan.",
        "x-i18n": {
          "zh-CN": {
            "summary": "创建项目",
            "description": "本接口可创建新项目并指定名称和订阅计划。"
          }
        },
        "tags": [
          "Project Operations (V2)"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "The authentication token should be an API key with appropriate privileges",
            "required": true,
            "example": "Bearer {{TOKEN}}",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "认证令牌，应为具备适当权限的 API 密钥。"
