{
  "openapi": "3.0.1",
  "info": {
    "title": "Restful API copy",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "Import Operations",
      "x-i18n": {
        "zh-CN": {
          "name": "Import"
        }
      }
    }
  ],
  "paths": {
    "/v1/vector/collections/import": {
      "post": {
        "summary": "Import",
        "deprecated": false,
        "description": "Imports data from files stored in a specified object storage bucket.",
        "x-i18n": {
          "zh-CN": {
            "summary": "导入",
            "description": "从指定对象存储桶中导入数据。"
          }
        },
        "tags": [
          "Import Operations"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "The authentication token should be an API key with appropriate privileges.",
            "required": true,
            "example": "Bearer {{TOKEN}}",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "认证令牌，应为具备适当权限的 API 密钥。"
              }
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "clusterId": {
                    "type": "string",
                    "description": "The ID of a cluster to which this operation applies.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "集群 ID。"
                      }
                    }
                  },
                  "collectionName": {
                    "type": "string",
                    "description": "The name of the collection to which this operation applies.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "Collection 名称。"
                      }
                    }
                  },
                  "partitionName": {
                    "type": "string",
                    "description": "The name of the partition to which this operation applies.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "Partition 名称。"
                      }
                    }
                  },
                  "objectUrl": {
                    "type": "string",
                    "description": "The URL of the object that stores the data to be imported.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "存储待导入数据的对象 URL。"
                      }
                    }
                  },
                  "accessKey": {
                    "type": "string",
                    "description": "The access key used to access the specified object.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "用于访问指定对象的 Access Key。"
                      }
                    }
                  },
                  "secretKey": {
                    "type": "string",
                    "description": "The secret access key used to access the specified object.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "用于访问指定对象的 Secret Key。"
                      }
                    }
                  }
                },
                "required": [
                  "collectionName",
                  "objectUrl",
                  "clusterId"
                ]
              },
              "examples": {
                "1": {
                  "summary": "request",
                  "value": {
                    "clusterId": "inxx-xxxxxxxxxxxxxxx",
                    "collectionName": "medium_articles",
                    "objectUrl": "gs://docs-demo/1af78216-xxxx-2b0a73c566ed/1.parquet",
                    "accessKey": "xxxxxx",
                    "secretKey": "xxxxxx"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns a import task job ID.",
            "x-i18n": {
              "zh-CN": {
                "description": "返回导入任务 ID。"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "x-tab-label": "success",
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "data": {
                          "type": "object",
                          "properties": {
                            "jobId": {
                              "type": "string",
                              "description": "The ID of the import job that has been submitted.",
                              "x-i18n": {
                                "zh-CN": {
                                  "description": "提交的导入任务的 ID。"
                                }
                              }
                            }
                          },
                          "required": [
                            "jobId"
                          ],
                          "description": "Response payload, which is an object containing the import job ID.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应载荷，为一个包含导入任务 ID 的对象。"
                            }
                          }
                        }
                      }
                    },
                    {
                      "x-tab-label": "failure",
                      "description": "Returns an error message.",
                      "x-i18n": {
                        "zh-CN": {
                          "description": "返回错误消息。"
                        }
                      },
                      "x-i18n-langs": [
                        "zh-CN"
                      ],
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "message": {
                          "type": "string",
                          "description": "Error message.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "错误描述。"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "1": {
                    "summary": "success",
                    "x-target-response": "OPTION 1",
                    "value": {
                      "code": 200,
                      "data": {
                        "jobId": "job-xxxxxxxxxxxxxxxxxxxxxx"
                      }
                    }
                  },
                  "2": {
                    "summary": "failure",
                    "x-target-response": "OPTION 2",
                    "value": {
                      "code": 80002,
                      "message": "Token not found or unauthorized: The provided token does not exist in our records, or you do not have the necessary permissions to use this token. Please ensure you have the correct token."
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/v1/vector/collections/import/get": {
      "get": {
        "summary": "Get Import Progress",
        "deprecated": false,
        "description": "Retrieves the progress of a specified import task.",
        "x-i18n": {
          "zh-CN": {
            "summary": "查看导入进度",
            "description": "查看指定导入任务的进度。"
          }
        },
        "tags": [
          "Import Operations"
        ],
        "parameters": [
          {
            "name": "jobId",
            "in": "query",
            "description": "The ID of the import task in concern",
            "required": true,
            "example": "job-xxxxxxxxxxxxxxxxxx",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "导入任务的 ID。"
              }
            }
          },
          {
            "name": "clusterId",
            "in": "query",
            "description": "The ID of a cluster to which this operation applies.",
            "required": true,
            "example": "inxx-xxxxxxxxxxxxxxx",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "集群 ID。"
              }
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "The authentication token should be an API key with appropriate privileges.",
            "required": true,
            "example": "Bearer {{TOKEN}}",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "认证令牌，应为具备适当权限的 API 密钥。"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the progress of the specified job ID in percentage.",
            "x-i18n": {
              "zh-CN": {
                "description": "以百分比形式返回指定任务 ID 的进度。"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "x-tab-label": "success",
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "data": {
                          "type": "object",
                          "description": "Response payload which is an object containing the progress of the import task.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "指定导入任务的进度详情。"
                            }
                          },
                          "properties": {
                            "fileName": {
                              "type": "string",
                              "description": "The path of the data file object in the object storage."
                            },
                            "fileSize": {
                              "type": "integer",
                              "description": "The size of the data file object.",
                              "format": "int64"
                            },
                            "readyPercentage": {
                              "type": "number",
                              "description": "The indicator of the import progress",
                              "format": "float"
                            },
                            "completeTime": {
                              "type": "string",
                              "description": "The time at which the import task completes. `null` indicates that the file import is going on.",
                              "nullable": true
                            },
                            "errorMessage": {
                              "type": "string",
                              "description": "The message that explains the reason for an import failure. `null` indicates that no error occurs.",
                              "nullable": true
                            },
                            "collectionName": {
                              "type": "string",
                              "description": "The target collection name of the import task."
                            },
                            "jobId": {
                              "type": "string",
                              "description": "The ID of an import task."
                            },
                            "details": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "description": "A list of import progress details per data files",
                                "x-i18n": {
                                  "zh-CN": {
                                    "description": "按数据文件维度分别收集的数据导入进度信息。"
                                  }
                                },
                                "properties": {
                                  "fileName": {
                                    "type": "string",
                                    "description": "The path to a file being imported."
                                  },
                                  "fileSize": {
                                    "type": "integer",
                                    "description": "The size of a file being imported.",
                                    "format": "int64"
                                  },
                                  "readyPercentage": {
                                    "type": "number",
                                    "description": "The import progress of a specific file.",
                                    "format": "float"
                                  },
                                  "completeTime": {
                                    "type": "string",
                                    "description": "The time at which the import progress ends for a specific file. `null` indicates that the file import is going on.",
                                    "nullable": true
                                  },
                                  "errorMessage": {
                                    "type": "string",
                                    "description": "The message that explains the reason for an import failure. `null` indicates that no error occurs.",
                                    "nullable": true
                                  }
                                }
                              },
                              "description": "The import task details"
                            }
                          }
                        }
                      }
                    },
                    {
                      "x-tab-label": "failure",
                      "description": "Returns an error message.",
                      "x-i18n": {
                        "zh-CN": {
                          "description": "返回错误消息。"
                        }
                      },
                      "x-i18n-langs": [
                        "zh-CN"
                      ],
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "message": {
                          "type": "string",
                          "description": "Error message.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "错误描述。"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "1": {
                    "summary": "success",
                    "x-target-response": "OPTION 1",
                    "value": {
                      "code": 200,
                      "data": {
                        "collectionName": "medium_articles",
                        "fileName": "1af78216-xxxx-xxxx-xxxx-2b0a73c566ed/1.parquet",
                        "fileSize": 19599887,
                        "readyPercentage": 0,
                        "completeTime": null,
                        "errorMessage": null,
                        "jobId": "job-xxxxxxxxxxxxxxxxxxxxxx",
                        "details": [
                          {
                            "fileName": "1af78216-xxxx-xxxx-xxxx-2b0a73c566ed/1.parquet",
                            "fileSize": 19599887,
                            "readyPercentage": 0,
                            "completeTime": null,
                            "errorMessage": null
                          }
                        ]
                      }
                    }
                  },
                  "2": {
                    "summary": "failure",
                    "x-target-response": "OPTION 2",
                    "value": {
                      "code": 1800,
                      "message": "User hasn't authenticated"
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/v1/vector/collections/import/list": {
      "get": {
        "summary": "List Import Jobs",
        "deprecated": false,
        "description": "List all import jobs specific to a cluster.",
        "x-i18n": {
          "zh-CN": {
            "summary": "查看导入任务列表",
            "description": "列出指定集群的导入任务。"
          }
        },
        "tags": [
          "Import Operations"
        ],
        "parameters": [
          {
            "name": "clusterId",
            "in": "query",
            "description": "The ID of a specific cluster on Zilliz Cloud.",
            "required": true,
            "example": "inxx-xxxxxxxxxxxxxxx",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "Zilliz Cloud 上的特定集群的 ID。"
              }
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of records to return at each request.",
            "required": false,
            "example": "10",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "每页返回记录数。"
              }
            }
          },
          {
            "name": "currentPage",
            "in": "query",
            "description": "The current page number.",
            "required": false,
            "example": "1",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "当前页码。"
              }
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "The authentication token should be an API key with appropriate privileges.",
            "required": true,
            "example": "Bearer {{TOKEN}}",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "认证令牌，应为具备适当权限的 API 密钥。"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns a list of import jobs.",
            "x-i18n": {
              "zh-CN": {
                "description": "返回导入任务列表。"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "x-tab-label": "success",
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "data": {
                          "type": "object",
                          "description": "Response payload which is a list containing import jobs in detail.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应负载，包含所有导入任务的详细信息。"
                            }
                          },
                          "properties": {
                            "count": {
                              "type": "string",
                              "description": "Total number of records listed in this response.",
                              "x-i18n": {
                                "zh-CN": {
                                  "description": "本次响应中列出的记录总数。"
                                }
                              }
                            },
                            "currentPage": {
                              "type": "string",
                              "description": "The current page number for your reference.",
                              "x-i18n": {
                                "zh-CN": {
                                  "description": "用于参考的当前页码。"
                                }
                              }
                            },
                            "pageSize": {
                              "type": "string",
                              "description": "The maximum number of records to be included in each return.",
                              "x-i18n": {
                                "zh-CN": {
                                  "description": "每页返回的最大记录数。"
                                }
                              }
                            },
                            "tasks": {
                              "type": "array",
                              "description": "A list of import jobs in detail.",
                              "x-i18n": {
                                "zh-CN": {
                                  "description": "导入任务的详细列表。"
                                }
                              },
                              "items": {
                                "type": "object",
                                "description": "A import job in detail.",
                                "x-i18n": {
                                  "zh-CN": {
                                    "description": "某个导入任务的详细信息。"
                                  }
                                },
                                "properties": {
                                  "collectionName": {
                                    "type": "string",
                                    "description": "The target collection name of a import task.",
                                    "x-i18n": {
                                      "zh-CN": {
                                        "description": "导入任务的目标 Collection 名称。"
                                      }
                                    }
                                  },
                                  "jobId": {
                                    "type": "string",
                                    "description": "The ID of an import task.",
                                    "x-i18n": {
                                      "zh-CN": {
                                        "description": "导入任务的 ID。"
                                      }
                                    }
                                  },
                                  "state": {
                                    "type": "string",
                                    "description": "The corresponding status of the import task. Possible values are <b>ImportRunning</b>, <b>ImportCompleted</b> and <b>ImportFailed</b>.",
                                    "x-i18n": {
                                      "zh-CN": {
                                        "description": "导入任务的对应状态。可能的值为 <b>ImportRunning</b>、<b>ImportCompleted</b> 和 <b>ImportFailed</b>。"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "x-tab-label": "failure",
                      "description": "Returns an error message.",
                      "x-i18n": {
                        "zh-CN": {
                          "description": "返回错误消息。"
                        }
                      },
                      "x-i18n-langs": [
                        "zh-CN"
                      ],
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "message": {
                          "type": "string",
                          "description": "Error message.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "错误描述。"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "1": {
                    "summary": "success",
                    "x-target-response": "OPTION 1",
                    "value": {
                      "code": 200,
                      "data": {
                        "tasks": [
                          {
                            "collectionName": "medium_articles",
                            "jobId": "job-xxxxxxxxxxxxxxxxxxxxxx",
                            "state": "ImportRunning"
                          },
                          {
                            "collectionName": "medium_articles",
                            "jobId": "2b93fef7-xxxx-xxxx-xxxx-f82afd598ff1",
                            "state": "ImportCompleted"
                          }
                        ],
                        "count": 2,
                        "currentPage": 1,
                        "pageSize": 10
                      }
                    }
                  },
                  "2": {
                    "x-target-response": "OPTION 2",
                    "summary": "failure",
                    "value": {
                      "code": 80002,
                      "message": "Token not found or unauthorized: The provided token does not exist in our records, or you do not have the necessary permissions to use this token. Please ensure you have the correct token."
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "servers": []
}
