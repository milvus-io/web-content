    "/v2/volumes/create": {
      "post": {
        "summary": "Create Volume",
        "deprecated": false,
        "description": "This operation creates a new volume in the specified project.",
        "x-i18n": {
          "zh-CN": {
            "summary": "创建 Volume",
            "description": "本接口用于在指定项目下创建一个新的 Volume。"
          }
        },
        "tags": [
          "Volume Operations (V2)"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "The authentication token should be an API key with appropriate privileges.",
            "required": true,
            "example": "Bearer {{TOKEN}}",
            "schema": {
              "type": "string"
            },
            "x-i18n": {
              "zh-CN": {
                "description": "认证令牌，应为具备适当权限的 API 密钥。"
              }
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "projectId": {
                    "type": "string",
                    "description": "The ID of the project to which the volume belongs.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "所属项目的 ID。"
                      }
                    },
                    "example": "proj-xxxxxxxxxxxxxxxxxxxxxxx"
                  },
                  "regionId": {
                    "type": "string",
                    "description": "The ID of the region where the volume will be created. You can use [List Cloud Regions](/reference/list-cloud-regions-v2) to list available regions. The region should be bound to the specified project.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "Volume 所属区域的 ID。您可以使用 [查看云服务区域](/reference/list-cloud-regions-v2) 接口列出可用区域。该区域应与指定项目绑定。"
                      }
                    }
                  },
                  "volumeName": {
                    "type": "string",
                    "description": "The name of the volume to create.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "Volume 名称。"
                      }
                    }
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the volume.",
                    "example": "Raw import data for recommendation workloads",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "Volume 描述。",
                        "example": "Raw import data for recommendation workloads"
                      }
                    }
                  },
                  "type": {
                    "type": "string",
                    "description": "The category of the volume. Valid values are `MANAGED` and `EXTERNAL`. Defaults to `MANAGED`.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "Volume 的类别。有效值为 `MANAGED` 和 `EXTERNAL`。默认值为 `MANAGED`。"
                      }
                    }
                  },
                  "storageIntegrationId": {
                    "type": "string",
                    "description": "The storage integration ID. Required when `type` is `EXTERNAL`.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "存储集成 ID。当 `type` 为 `EXTERNAL` 时必填。"
                      }
                    }
                  },
                  "path": {
                    "type": "string",
                    "description": "The path prefix within the volume. Required when `type` is `EXTERNAL`.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "存储卷内的路径前缀。当 `type` 为 `EXTERNAL` 时必填。"
                      }
                    }
                  }
                },
                "required": [
                  "volumeName",
                  "regionId",
                  "projectId"
                ]
              },
              "examples": {
                "1": {
                  "summary": "Managed Volume",
                  "x-target-response": "OPTION 1",
                  "x-target-lang": "en-US",
                  "value": {
                    "projectId": "proj-xxxxxxxxxxxxxxxxxxxxxxx",
                    "regionId": "aws-us-west-2",
                    "volumeName": "my_volume",
                    "description": "A volume for storing collection data."
                  }
                },
                "2": {
                  "summary": "Managed Volume",
                  "x-target-response": "OPTION 1",
                  "x-target-lang": "zh-CN",
                  "value": {
                    "projectId": "proj-xxxxxxxxxxxxxxxxxxxxxxx",
                    "regionId": "ali-cn-hangzhou",
                    "volumeName": "my_volume",
                    "description": "用于存储集合数据的卷描述。"
                  }
                },
                "3": {
                  "summary": "External Volume",
                  "x-target-response": "OPTION 1",
                  "x-target-lang": "en-US",
                  "value": {
                    "projectId": "proj-xxxxxxxxxxxxxxxxxxxxxxx",
                    "regionId": "aws-us-west-2",
                    "volumeName": "my_external_volume",
                    "type": "EXTERNAL",
                    "storageIntegrationId": "integ-xxxxxxxxxxxxxxxxxxx",
                    "path": "data/",
                    "description": "A volume for storing collection data."
                  }
                },
                "4": {
                  "summary": "External Volume",
                  "x-target-response": "OPTION 1",
                  "x-target-lang": "zh-CN",
                  "value": {
                    "projectId": "proj-xxxxxxxxxxxxxxxxxxxxxxx",
                    "regionId": "ali-cn-hangzhou",
                    "volumeName": "my_external_volume",
                    "type": "EXTERNAL",
                    "storageIntegrationId": "integ-xxxxxxxxxxxxxxxxxxx",
                    "path": "data/",
                    "description": "用于存储集合数据的卷描述。"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returns the name of the created volume.",
            "x-i18n": {
              "zh-CN": {
                "description": "返回已创建的 Volume 名称。"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    {
                      "x-tab-label": "success",
                      "description": "Returns the created volume name.",
                      "x-i18n": {
                        "zh-CN": {
                          "description": "返回已创建的 Volume 名称。"
                        }
                      },
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "data": {
                          "type": "object",
                          "properties": {
                            "volumeName": {
                              "type": "string",
                              "description": "The name of the created volume.",
                              "x-i18n": {
                                "zh-CN": {
                                  "description": "已创建的 Volume 名称。"
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "x-tab-label": "failure",
                      "description": "Returns an error message.",
                      "x-i18n": {
                        "zh-CN": {
                          "description": "返回错误消息。"
                        }
                      },
                      "x-i18n-langs": [
                        "zh-CN"
                      ],
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "integer",
                          "description": "Response code.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "响应码。"
                            }
                          }
                        },
                        "message": {
                          "type": "string",
                          "description": "Error message.",
                          "x-i18n": {
                            "zh-CN": {
                              "description": "错误描述。"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "examples": {
                  "1": {
                    "summary": "success",
                    "x-target-response": "OPTION 1",
                    "value": {
                      "code": 0,
                      "data": {
                        "volumeName": "my_volume"
                      }
                    }
                  },
                  "2": {
                    "summary": "failure",
                    "x-target-response": "OPTION 2",
                    "value": {
                      "code": 1800,
                      "message": "User hasn't authenticated"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
