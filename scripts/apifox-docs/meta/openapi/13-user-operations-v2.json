    "/v2/vectordb/users/update_password": {
      "post": {
        "summary": "Update User",
        "deprecated": false,
        "description": "This operation updates the password or description of a specified user.",
        "x-i18n": {
          "zh-CN": {
            "summary": "更新用户",
            "description": "本操作可更新指定用户的密码或描述。"
          }
        },
        "tags": [
          "User Operations (V2)"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "The authentication token should be <include target=\"zilliz\">an API key with appropriate privileges or </include>a pair of colon-joined username and password, like `username:password`.",
            "x-i18n": {
              "zh-CN": {
                "description": "认证令牌。应为<include target=\"zilliz\">具备适当权限的 API 密钥或</include>用冒号分隔的用户名和密码，如 `username:password`。"
              }
            },
            "required": true,
            "example": "Bearer {{TOKEN}}",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userName": {
                    "type": "string",
                    "description": "The name of the target user. The value should start with a letter and can only contain underline, letters and numbers.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "待创建用户的用户名。\n用户名须以字母开头，并包含下划线、字母和数字。"
                      }
                    }
                  },
                  "password": {
                    "type": "string",
                    "description": "The current password of the user. Provide this field together with `newPassword` when changing the password.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "用户当前密码。修改密码时，需与 `newPassword` 一起提供。"
                      }
                    },
                    "minLength": 8,
                    "maxLength": 64,
                    "format": "password"
                  },
                  "newPassword": {
                    "type": "string",
                    "description": "The new password for the user. Provide this field together with `password` when changing the password.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "用户的新密码。修改密码时，需与 `password` 一起提供。"
                      }
                    },
                    "format": "password",
                    "minLength": 8,
                    "maxLength": 64
                  },
                  "description": {
                    "type": "string",
                    "description": "The new description of the user. The value can be an empty string.",
                    "x-i18n": {
                      "zh-CN": {
                        "description": "用户的新描述。该值可以为空字符串。"
                      }
                    }
                  }
                },
                "required": [
                  "userName"
                ],
                "x-i18n-langs": [
                  "zh-CN"
                ]
              },
              "example": {
                "newPassword": "P@ssw0rd!",
                "userName": "myUser",
                "password": "P@ssw0rd*"
              },
              "examples": {
                "1": {
                  "summary": "Update password",
                  "value": {
                    "userName": "myUser",
                    "password": "P@ssw0rd*",
                    "newPassword": "P@ssw0rd!"
                  }
                },
                "2": {
                  "summary": "Update description",
                  "value": {
                    "userName": "myUser",
                    "description": "Read-only analyst account."
                  }
                }
              }
            }
          }
        },
